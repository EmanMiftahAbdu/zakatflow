# Backend
DATABASE_URL=sqlite:///./zakatflow.db
SECRET_KEY=change-me-to-a-random-string
CORS_ORIGINS=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Plaid — get keys at https://dashboard.plaid.com/team/keys
# PLAID_ENV must be one of: sandbox, development, production
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox
PLAID_PRODUCTS=["auth","transactions"]
PLAID_COUNTRY_CODES=["US"]
PLAID_LANGUAGE=en
PLAID_WEBHOOK_URL=http://localhost:8000/api/plaid/webhook
PLAID_CLIENT_NAME=ZakatFlow

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
